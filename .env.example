# NexusFlow Environment Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required if using Gemini provider)
# Get your key at: https://aistudio.google.com/apikey
VITE_API_KEY=

# App Configuration
VITE_APP_TITLE=NexusFlow

# Note: Ollama runs locally and doesn't require an API key.
# To use Ollama, ensure it's running with CORS enabled:
#   OLLAMA_ORIGINS="*" ollama serve
#
# Then select "Ollama (Local)" in the Settings modal.
